<Window x:Class="BeyondSosariaLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beyond Sosaria Launcher"
        Width="480" Height="520"
        MinWidth="420" MinHeight="480"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PanelBg"       Color="#16213E"/>
        <SolidColorBrush x:Key="AccentBrush"   Color="#0F3460"/>
        <SolidColorBrush x:Key="HighlightBrush" Color="#E94560"/>
        <SolidColorBrush x:Key="TextBrush"     Color="#E0E0E0"/>
        <SolidColorBrush x:Key="DimTextBrush"  Color="#888888"/>
        <SolidColorBrush x:Key="InputBg"       Color="#0D1B2A"/>
        <SolidColorBrush x:Key="BorderBrush"   Color="#2A2A4A"/>

        <!-- Base TextBox style -->
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background"   Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="Height"       Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"   Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="DarkPassword" TargetType="PasswordBox">
            <Setter Property="Background"   Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="Height"       Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background"   Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"       Value="30"/>
        </Style>

        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="10,4"/>
            <Setter Property="Height"       Value="30"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HighlightBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlayButton" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource HighlightBrush}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"     Value="16"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Height"       Value="44"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource DimTextBrush}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Update banner -->
            <RowDefinition Height="Auto"/>  <!-- Server + UO path -->
            <RowDefinition Height="Auto"/>  <!-- Credentials -->
            <RowDefinition Height="Auto"/>  <!-- Plugins -->
            <RowDefinition Height="*"/>     <!-- Spacer -->
            <RowDefinition Height="Auto"/>  <!-- Play + progress -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Beyond Sosaria"
                       Foreground="{StaticResource HighlightBrush}"
                       FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="VersionText"
                       Text="Checking for updates…"
                       Foreground="{StaticResource DimTextBrush}"
                       FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- ── Update banner ── -->
        <Border Grid.Row="1"
                x:Name="UpdateBanner"
                Background="#2A1A00"
                BorderBrush="#E94560"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                Margin="0,0,0,10"
                Visibility="Collapsed">
            <DockPanel>
                <TextBlock x:Name="UpdateBannerText"
                           Foreground="#FFD700"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Text="Update available!"
                           DockPanel.Dock="Left"/>
                <Button x:Name="DownloadUpdateBtn"
                        Content="Download"
                        Style="{StaticResource SmallButton}"
                        HorizontalAlignment="Right"
                        Click="DownloadUpdateBtn_Click"/>
            </DockPanel>
        </Border>

        <!-- ── Server + UO Path ── -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Server row -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Server"
                       Style="{StaticResource SectionLabel}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="0" Grid.Column="1"
                      x:Name="ServerCombo"
                      Style="{StaticResource DarkCombo}"
                      DisplayMemberPath="Name"
                      SelectionChanged="ServerCombo_SelectionChanged"/>
            <Button Grid.Row="0" Grid.Column="2"
                    Content="+ Add"
                    Style="{StaticResource SmallButton}"
                    Margin="6,0,0,0"
                    Click="AddServerBtn_Click"/>

            <!-- UO Path row -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="UO Path"
                       Style="{StaticResource SectionLabel}"
                       VerticalAlignment="Center" Margin="0,8,8,0"/>
            <TextBox Grid.Row="1" Grid.Column="1"
                     x:Name="UoPathBox"
                     Style="{StaticResource DarkInput}"
                     Margin="0,8,0,0"
                     TextChanged="UoPathBox_TextChanged"/>
            <Button Grid.Row="1" Grid.Column="2"
                    Content="Browse"
                    Style="{StaticResource SmallButton}"
                    Margin="6,8,0,0"
                    Click="BrowseUoPath_Click"/>
        </Grid>

        <!-- ── Credentials ── -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Username"
                       Style="{StaticResource SectionLabel}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Row="0" Grid.Column="1"
                     x:Name="UsernameBox"
                     Style="{StaticResource DarkInput}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Password"
                       Style="{StaticResource SectionLabel}"
                       VerticalAlignment="Center" Margin="0,8,8,0"/>
            <PasswordBox Grid.Row="1" Grid.Column="1"
                         x:Name="PasswordBox"
                         Style="{StaticResource DarkPassword}"
                         Margin="0,8,0,0"/>

            <CheckBox Grid.Row="2" Grid.Column="1"
                      x:Name="RememberPasswordCheck"
                      Content="Remember password"
                      Style="{StaticResource DarkCheck}"
                      Margin="0,6,0,0"/>
        </Grid>

        <!-- ── Plugins ── -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="PLUGINS" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
            <ItemsControl x:Name="PluginsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}"
                                  IsChecked="{Binding IsEnabled}"
                                  Style="{StaticResource DarkCheck}"
                                  Margin="0,2"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- ── Spacer ── -->
        <Grid Grid.Row="5"/>

        <!-- ── Play + Download progress ── -->
        <StackPanel Grid.Row="6" Margin="0,6,0,0">
            <Button x:Name="PlayBtn"
                    Content="PLAY"
                    Style="{StaticResource PlayButton}"
                    Click="PlayBtn_Click"
                    IsEnabled="False"/>

            <!-- Download progress (hidden until active) -->
            <Grid x:Name="DownloadPanel" Visibility="Collapsed" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar x:Name="DownloadProgress"
                             Grid.Column="0"
                             Height="20"
                             Background="{StaticResource InputBg}"
                             Foreground="{StaticResource HighlightBrush}"
                             BorderThickness="0"
                             Minimum="0" Maximum="100"/>
                <TextBlock x:Name="DownloadPct"
                           Grid.Column="1"
                           Foreground="{StaticResource TextBrush}"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Text="0%"/>
            </Grid>

            <TextBlock x:Name="StatusText"
                       Foreground="{StaticResource DimTextBrush}"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
